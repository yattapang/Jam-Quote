# --- Core ---
NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jamquote?schema=public"
JWT_SECRET="change-me-in-production"

# --- WiPay (payments) ---
WIPAY_ACCOUNT_NUMBER=""
WIPAY_API_KEY=""
WIPAY_ENVIRONMENT="sandbox"      # sandbox | live
WIPAY_COUNTRY_CODE="JM"
WIPAY_CURRENCY="JMD"
WIPAY_CALLBACK_URL="http://localhost:3001/payments/wipay/webhook"

# --- Messaging ---
# Phase 1 uses WhatsApp click-to-chat (no key needed). Phase 2:
WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Email (transactional relay fallback)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# --- Storage (site photos, logos, scans) ---
S3_ENDPOINT=""
S3_BUCKET="jamquote"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
