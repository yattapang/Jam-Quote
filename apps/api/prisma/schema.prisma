// JamQuote data model. Money is ALWAYS integer JMD cents (see packages/core).
// Enums mirror packages/core/src/types/enums.ts exactly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum LineCategory {
  MATERIAL
  LABOUR
  EQUIPMENT
  RENTAL
  SUBCONTRACTOR
  OTHER
}

enum RateUnit {
  HOUR
  DAY
  WEEK
  MONTH
  JOB
  UNIT
}

enum GctTreatment {
  STANDARD
  ZERO_RATED
  EXEMPT
}

enum PriceSource {
  MANUAL
  LOOKUP
  SCAN
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  INVOICED
}

enum InvoiceStatus {
  DRAFT
  INVOICED
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CARD
  CASH
  BANK_TRANSFER
  LYNK
  OTHER
}

enum UserRole {
  OWNER
  STAFF
  ADMIN // internal JamQuote staff (admin portal)
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

// ---------------------------------------------------------------------------
// Tenancy & identity
// ---------------------------------------------------------------------------
model Business {
  id             String  @id @default(uuid())
  name           String
  trn            String? // 9 digits, validated in app layer
  logoUrl        String?
  addressLine    String?
  parish         String?
  tradeType      String?
  defaultGctRate Decimal @default(15.0) @db.Decimal(5, 2)
  quotePrefix    String  @default("QT-")
  invoicePrefix  String  @default("INV-")
  nextQuoteSeq   Int     @default(1)
  nextInvoiceSeq Int     @default(1)
  jmdPerUsd      Decimal? @db.Decimal(10, 4) // optional USD reference rate
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users         User[]
  clients       Client[]
  jobs          Job[]
  quotes        Quote[]
  invoices      Invoice[]
  labourRates   LabourRate[]
  materialFavs  MaterialFavourite[]
  equipment     EquipmentItem[]
  connections   Connection[]
  subscription  Subscription?
}

model User {
  id           String   @id @default(uuid())
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id])
  role         UserRole @default(OWNER)
  fullName     String?
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Clients & jobs
// ---------------------------------------------------------------------------
model Client {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  phone       String?
  whatsapp    String?
  email       String?
  addressLine String?
  parish      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs     Job[]
  quotes   Quote[]
  invoices Invoice[]

  @@index([businessId])
}

model Job {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  name        String
  addressLine String?
  parish      String?
  stage       String   @default("Quoted")
  progressPct Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotes      Quote[]
  attachments Attachment[]

  @@index([businessId])
  @@index([clientId])
}

// ---------------------------------------------------------------------------
// Quotes
// ---------------------------------------------------------------------------
model Quote {
  id            String      @id @default(uuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id])
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  jobId         String?
  job           Job?        @relation(fields: [jobId], references: [id])
  number        String // e.g. QT-0142
  status        QuoteStatus @default(DRAFT)
  version       Int         @default(1)
  parentQuoteId String? // for revisions
  gctRate       Decimal     @db.Decimal(5, 2)
  discountPct   Decimal     @default(0) @db.Decimal(5, 2)
  depositCents  Int         @default(0)
  validUntil    DateTime?
  terms         String?
  // Denormalized computed totals (source of truth = packages/core).
  subtotalCents Int         @default(0)
  gctCents      Int         @default(0)
  totalCents    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sections  QuoteSection[]
  lineItems QuoteLineItem[]
  invoices  Invoice[]
  messages  MessageLog[]

  @@unique([businessId, number, version])
  @@index([businessId, status])
  @@index([clientId])
}

model QuoteSection {
  id      String @id @default(uuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  title   String
  sort    Int    @default(0)

  lineItems QuoteLineItem[]
}

model QuoteLineItem {
  id             String       @id @default(uuid())
  quoteId        String
  quote          Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        QuoteSection? @relation(fields: [sectionId], references: [id])
  category       LineCategory
  description    String
  quantity       Decimal      @db.Decimal(12, 3)
  rateUnit       RateUnit     @default(UNIT)
  unitPriceCents Int
  priceSource    PriceSource  @default(MANUAL)
  supplierId     String?
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
  gctTreatment   GctTreatment @default(STANDARD)
  markupPct      Decimal?     @db.Decimal(6, 2)
  overrideNote   String?
  sort           Int          @default(0)

  @@index([quoteId])
}

// ---------------------------------------------------------------------------
// Catalogs & pricing
// ---------------------------------------------------------------------------
model Supplier {
  id        String   @id @default(uuid())
  name      String
  website   String?
  parish    String?
  isPartner Boolean  @default(false)
  createdAt DateTime @default(now())

  priceEntries MaterialPriceEntry[]
  lineItems    QuoteLineItem[]
}

model MaterialPriceEntry {
  id          String      @id @default(uuid())
  supplierId  String
  supplier    Supplier    @relation(fields: [supplierId], references: [id])
  name        String
  sku         String?
  unit        String? // "42.5kg bag", "20ft length"
  priceCents  Int
  source      PriceSource @default(LOOKUP)
  sourceUrl   String?
  fetchedAt   DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@index([supplierId])
  @@index([name])
}

model LabourRate {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  trade      String // mason, electrician, helper...
  skillTier  String? // helper / journeyman / master
  rateCents  Int
  rateUnit   RateUnit @default(DAY)

  @@index([businessId])
}

model MaterialFavourite {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  unit       String?
  priceCents Int
  supplierId String?

  @@index([businessId])
}

model EquipmentItem {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  owned      Boolean  @default(false)
  vendor     String?
  vendorPhone String?
  rateCents  Int
  rateUnit   RateUnit @default(DAY)

  @@index([businessId])
}

// ---------------------------------------------------------------------------
// Invoicing & payments
// ---------------------------------------------------------------------------
model Invoice {
  id            String        @id @default(uuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id])
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id])
  number        String
  status        InvoiceStatus @default(INVOICED)
  totalCents    Int
  paidCents     Int           @default(0)
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments Payment[]

  @@unique([businessId, number])
  @@index([businessId, status])
}

model Payment {
  id           String        @id @default(uuid())
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountCents  Int
  method       PaymentMethod
  // WiPay linkage
  providerRef  String? // WiPay transaction id
  providerRaw  Json? // raw webhook payload for audit
  status       String        @default("recorded") // recorded | pending | completed | failed
  paidAt       DateTime      @default(now())
  createdAt    DateTime      @default(now())

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Messaging, regulatory, attachments, subscription
// ---------------------------------------------------------------------------
model MessageLog {
  id        String         @id @default(uuid())
  quoteId   String?
  quote     Quote?         @relation(fields: [quoteId], references: [id])
  channel   MessageChannel
  toAddress String
  status    String         @default("sent") // sent | delivered | read | failed
  sentAt    DateTime       @default(now())
}

model Connection {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  channel    MessageChannel
  // e.g. linked WhatsApp business number or OAuth email account
  identifier String?
  accessData Json?
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model RegulatoryUpdate {
  id            String   @id @default(uuid())
  title         String
  category      String // GCT | NHT | TRN | MIN_WAGE | PERMIT | OTHER
  summary       String
  effectiveDate DateTime?
  actionNeeded  String?
  sourceUrl     String?
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([category])
}

model Attachment {
  id        String   @id @default(uuid())
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id])
  url       String
  kind      String   @default("photo")
  createdAt DateTime @default(now())
}

model Subscription {
  id         String   @id @default(uuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id])
  plan       String   @default("free") // free | pro
  status     String   @default("active")
  renewsAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
