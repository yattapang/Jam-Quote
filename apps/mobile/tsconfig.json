{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@jamquote/core": ["../../packages/core/src/index.ts"],
      "@jamquote/core/*": ["../../packages/core/src/*"],
      "@jamquote/ui": ["../../packages/ui/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
